datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/prisma"
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  invitesSent  InviteToken[] @relation("InviteCreatedBy")
  activityLogs ActivityLog[]
  sessions     Session[]
  accounts     Account[]

  @@map("user")
}

model InviteToken {
  id      String   @id @default(cuid())
  token   String   @unique @default(cuid())
  email   String
  used    Boolean  @default(false)
  expires DateTime

  createdBy     String
  createdByUser User   @relation("InviteCreatedBy", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())

  @@index([createdBy])
}

// ─────────────────────────────────────────────
// PORTAL CONTENT
// ─────────────────────────────────────────────

model Category {
  id          String @id @default(cuid())
  title       String // "Здоров'я"
  titleEn     String // "Health"
  slug        String @unique
  iconName    String // "Heart" — lucide icon name
  photo       String
  description String
  accent      String @default("#3b82f6") // HEX колір акценту
  bg          String @default("#eff6ff") // HEX фону іконки
  order       Int    @default(0) // для ручного сортування

  services      String[]
  subcategories Subcategory[]
  resources     Resource[]
  activityLogs  ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  id          String @id @default(cuid())
  title       String // "Лікарні"
  titleEn     String // "Hospitals"
  description String
  order       Int    @default(0)
  slug        String @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  resources    Resource[]
  activityLogs ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Resource {
  id          String   @id @default(cuid())
  title       String // "Черкаська обласна лікарня"
  icon        String
  description String? // короткий опис
  url         String // https://...
  tags        String[] // ["лікарня", "стаціонар"]
  order       Int      @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  activityLogs ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([subcategoryId])
}

// ─────────────────────────────────────────────
// FEEDBACK
// ─────────────────────────────────────────────

enum FeedbackType {
  FEEDBACK // загальний відгук
  ADD_RESOURCE // пропозиція додати ресурс
  REMOVE_RESOURCE // запит видалити ресурс
  ADD_CATEGORY // пропозиція нової категорії
}

enum FeedbackStatus {
  NEW // нове, не переглянуто
  REVIEWED // переглянуто
  RESOLVED // вирішено
}

model Feedback {
  id     String         @id @default(cuid())
  type   FeedbackType   @default(FEEDBACK)
  status FeedbackStatus @default(NEW)

  subject String
  message String
  author  String // ім'я відправника
  email   String // email відправника

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ACTIVITY LOG
// ─────────────────────────────────────────────

enum LogAction {
  CREATE
  EDIT
  DELETE
  LOGIN
  LOGOUT
  INVITE
}

enum LogEntity {
  CATEGORY
  SUBCATEGORY
  RESOURCE
  ADMIN
  SETTINGS
}

model ActivityLog {
  id         String    @id @default(cuid())
  action     LogAction
  entity     LogEntity
  entityName String // snapshot назви на момент дії
  details    String? // додаткові деталі

  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName String // snapshot імені на момент дії

  // опціональні зв'язки для швидкого пошуку логів по об'єкту
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([categoryId])
  @@index([resourceId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
